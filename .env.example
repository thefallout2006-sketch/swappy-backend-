# ─── DATABASE ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=swappy_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── SERVER ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT AUTH ────────────────────────────────────────────────
JWT_SECRET=swappy_super_secret_key_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=30d

# ─── OTP ─────────────────────────────────────────────────────
# Set to 'true' in development to use fixed OTP (123456) instead of SMS
OTP_DEV_MODE=true

# When OTP_DEV_MODE=false, add your SMS provider credentials below.
# Recommended: Fast2SMS (Indian provider, easy signup, cheap)
# Sign up at https://fast2sms.com — free 50 SMS credits on signup
FAST2SMS_API_KEY=your_fast2sms_key_here

# ─── FILE UPLOADS ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ─── FRONTEND URL (for CORS) ─────────────────────────────────
FRONTEND_URL=http://localhost:5173
